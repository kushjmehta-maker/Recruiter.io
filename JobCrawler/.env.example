# MongoDB
MONGODB_URI=mongodb://localhost:27017/jobcrawler

# Anthropic (Claude API for relevance scoring)
ANTHROPIC_API_KEY=sk-ant-...

# SendGrid (email alerts)
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=alerts@yourdomain.com
SENDGRID_FROM_NAME=JobCrawler Alerts

# Apify (web scraping for custom portals)
APIFY_API_TOKEN=apify_api_...

# Server
PORT=3000
NODE_ENV=development

# Extension
EXTENSION_CORS_ORIGIN=chrome-extension://your-extension-id
