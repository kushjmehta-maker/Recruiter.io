{
  "manifest_version": 3,
  "name": "JobCrawler - Smart Job Finder",
  "version": "1.0.0",
  "description": "Crawl 50+ company career portals, match jobs to your resume, and get email alerts for high-relevance openings.",
  "permissions": ["storage", "alarms"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
