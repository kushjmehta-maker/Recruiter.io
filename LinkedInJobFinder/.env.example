# Azure AI Foundry / AI Inference credentials.
# Get the key from the Azure portal -> your AI Services resource -> Keys and Endpoint.
# After pasting, treat the key as a secret: never commit .env, rotate if exposed.

AZURE_AI_API_KEY=
AZURE_AI_ENDPOINT=https://YOUR-RESOURCE.services.ai.azure.com/models
AZURE_AI_DEPLOYMENT=gpt-5.4-pro
AZURE_AI_API_VERSION=2024-10-21

# Optional: cloud mirror via Azure Blob Storage.
# When set on the Mac, the daily pipeline pushes jobs.db / job_tracker.csv /
# last_run.log / drafts to the storage account after each run. When set on the
# App Service (alongside LINKEDIN_FINDER_REMOTE=1), the Streamlit UI reads from
# the same blobs. Set up via `bash infra/deploy.sh` — see README "Cloud mirror".
# BLOB_ACCOUNT_URL=https://YOUR-STORAGE-ACCOUNT.blob.core.windows.net
# BLOB_STATE_CONTAINER=state
# BLOB_DRAFTS_CONTAINER=drafts
